# ---- LLM (search app) ----
# Master AI on/off switch (set on Vercel to lock the public demo down without a
# code change). Leave unset = AI ON. Set to false/0/off/no to disable ALL AI
# features; the classic keyword search / register / court filters keep working.
#   AI_ENABLED=false
# If ANTHROPIC_API_KEY is missing or invalid, every AI surface shows
# "AI Key is not available." and falls back to classic search.
ANTHROPIC_API_KEY=sk-ant-...

# Provider switch. Only "claude" is implemented today.
LLM_PROVIDER=claude
# GEMINI_API_KEY=            # reserved for a future provider

# Operator token for the suggestions "Reset" control (clears the query log).
# On a public deploy, set this and reset is gated to whoever holds the token
# (open it once via /search?admin=<token>). Unset = reset disabled in
# production, always allowed in local dev.
#   SUGGESTIONS_RESET_TOKEN=choose-a-long-random-string

# Optional model overrides (sensible defaults used if unset):
#   CLAUDE_MODEL        — answer + card layout (default: claude-sonnet-4-6)
#   CLAUDE_STEPS_MODEL  — fast "thinking" step labels (default: claude-haiku-4-5-20251001)
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_STEPS_MODEL=claude-haiku-4-5-20251001

# ---- Supabase (vector store) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# ---- Crawler / ingestion (only needed to re-run the crawl) ----
CRAWL_MIN_DELAY_MS=1200
CRAWL_MAX_DELAY_MS=2500
CRAWL_CONCURRENCY=1
CRAWL_HEADFUL=false
