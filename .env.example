# ---- LLM (search app) ----
# Provider switch. Only "claude" is implemented today.
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=            # reserved for a future provider

# Optional model overrides (sensible defaults used if unset):
#   CLAUDE_MODEL        — answer + card layout (default: claude-sonnet-4-6)
#   CLAUDE_STEPS_MODEL  — fast "thinking" step labels (default: claude-haiku-4-5-20251001)
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_STEPS_MODEL=claude-haiku-4-5-20251001

# ---- Supabase (vector store) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# ---- Crawler / ingestion (only needed to re-run the crawl) ----
CRAWL_MIN_DELAY_MS=1200
CRAWL_MAX_DELAY_MS=2500
CRAWL_CONCURRENCY=1
CRAWL_HEADFUL=false
